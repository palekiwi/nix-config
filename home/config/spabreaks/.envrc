use flake

export BROWSER="google-chrome-stable"

export GEMINI_API_KEY="$(cat /run/secrets/spabreaks/gemini_api_key)"
export ANTHROPIC_API_KEY="$(cat /run/secrets/spabreaks/anthropic/dev-02-01)"

export JIRA_EMAIL="$(cat /run/secrets/jira/email)"
export JIRA_TOKEN="$(cat /run/secrets/jira/token)"

export JIRA_URL="https://spabreaks.atlassian.net"
export JIRA_BOARD_ID="74"
export JIRA_PROJECT="SB"

export SB_AIRBRAKE_AUTH_TOKEN="$(cat /run/secrets/spabreaks/airbrake_auth_token)"

export OCX_DATA_VOLUMES_NAME="ocx-sb"
export CAST_VOLUMES_NAMESPACE="cast-sb"

export CUE_BRANCH_NAME="cue-palekiwi"

export GITHUB_USER="palekiwi"
